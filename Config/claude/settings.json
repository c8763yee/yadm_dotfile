{
  "model": "sonnet",
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "pensieve@kingkongshot-marketplace": true,
    "pua@pua-skills": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "kingkongshot-marketplace": {
      "source": {
        "source": "github",
        "repo": "kingkongshot/Pensieve",
        "ref": "claude-plugin"
      }
    },
    "pua-skills": {
      "source": {
        "source": "github",
        "repo": "tanweai/pua"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(diff *)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(find *)",
      "Bash(which *)",
      "Bash(type *)",
      "Bash(file *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(cut *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(tr *)",
      "Bash(pwd)",
      "Bash(uname *)",
      "Bash(date *)",
      "Bash(stat *)",
      "Bash(du *)",
      "Bash(df *)",
      "Bash(ps *)",
      "Bash(jq *)"
    ]
  },
  "language": "#zh-TW",
  "effortLevel": "medium",
  "tui": "fullscreen",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
