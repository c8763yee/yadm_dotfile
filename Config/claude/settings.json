{
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "pensieve@kingkongshot-marketplace": true,
    "pua@pua-skills": true,
    "codex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "kingkongshot-marketplace": {
      "source": {
        "source": "github",
        "repo": "kingkongshot/Pensieve",
        "ref": "claude-plugin"
      }
    },
    "pua-skills": {
      "source": {
        "source": "github",
        "repo": "tanweai/pua"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "language": "#zh-TW",
  "effortLevel": "medium",
  "tui": "fullscreen",
  "agentPushNotifEnabled": true
}
